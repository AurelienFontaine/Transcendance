
{
  "compilerOptions": {
    "target": "ES2022",                         // Version JS
    "module": "ESNext",                         // Type de modules
    "outDir": "./dist",                         // Dossier de sortie (important pour main.js)
    "lib": ["ES2022", "DOM", "DOM.Iterable"],   // Fonctionnalités supportées
    "skipLibCheck": true,                       // Ignore les erreurs dans node_modules

    /* Résolution et compatibilité */
    "moduleResolution": "bundler",              // Recommandé avec Vite
    "verbatimModuleSyntax": true,               // Pour `import`/`export` modernes

    /* Vérifications utiles */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true,
  },
  "include": ["src", "../shared/game/types.ts", "../shared/game/sketch.ts"]
}

